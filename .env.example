# ========== NextAuth (필수) ==========
# 브라우저 접속 URL·OAuth 리다이렉트와 동일해야 함 (끝에 / 없음)
# 운영 기본: https://sejonglab.com  |  로컬 개발만: http://localhost:3003 (.env.local 권장)
NEXTAUTH_URL=https://sejonglab.com
NEXTAUTH_SECRET=your-secret-key-min-32-chars

# ========== OAuth 클라이언트 (사용할 것만 채움) ==========
# 각 개발자 콘솔 "승인된 리디렉션 URI"에 BASE/api/auth/callback/{google|kakao|naver} 등록
# 운영 예: https://sejonglab.com/api/auth/callback/google
#         https://sejonglab.com/api/auth/callback/kakao
#         https://sejonglab.com/api/auth/callback/naver
# 로컬 예: http://localhost:3003/api/auth/callback/...

# Google - Cloud Console > API 및 서비스 > 사용자 인증 정보 > OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kakao - 개발자 콘솔 > 앱 > 로그인 > Redirect URI
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Naver - 개발자 센터 > 애플리케이션 > API 설정 > Callback URL
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ========== 히어로 3번째 지표: 자율주행 누적 주행거리 (선택) ==========
# 공공데이터포털 [상세기능]의 전체 요청 URL을 넣으면 그대로 사용 (serviceKey 포함 가능)
# AUTONOMOUS_MILEAGE_API_URL="https://apis.data.go.kr/..."
# 인증키(서비스키) — 미설정 시 코드 내 기본키 또는 아래 중 하나 사용
# AUTONOMOUS_MILEAGE_API_KEY=""
# NEXT_PUBLIC_AUTONOMOUS_API_KEY=""
# 실패 시 "150,000+ km" 폴백. 표시만 고정: AUTONOMOUS_MILEAGE_DISPLAY="152,430+ km"

# ========== (레거시) 어울링 fetch 유틸 — 현재 히어로 미사용 시 생략 가능 ==========
# NEXT_PUBLIC_DATA_GO_KR_API_KEY=""
# DATA_GO_KR_API_KEY=

# ========== Database (선택, 없으면 JWT만 사용) ==========
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# ========== 설문 Webhook (/api/webhook/survey-response) ==========
# POST 요청 시 헤더 X-API-Key 또는 Authorization: Bearer <값> 과 동일해야 함
SURVEY_WEBHOOK_API_KEY=your-long-random-secret
